{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "WebFetch(*)",
      "WebFetch(domain:*)",
      "WebSearch(*)",
      "Task(*)",
      "TodoWrite(*)",
      "NotebookEdit(*)",
      "mcp__Claude_Preview__*",
      "mcp__Claude_in_Chrome__*",
      "mcp__mcp-registry__*",
      "Bash(curl -fsS http://localhost:4000/health)",
      "Bash(curl -fsS http://localhost:3000/)",
      "mcp__visualize__read_me",
      "mcp__visualize__show_widget"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/check-version-alignment.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
