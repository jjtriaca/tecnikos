# ═══════════════════════════════════════════════════════════════
#  Variáveis de produção — Sistema de Terceirização
#  Copie para .env.production e preencha os valores reais
#  NUNCA commite este arquivo com valores reais
# ═══════════════════════════════════════════════════════════════

# ── Banco de dados ────────────────────────────────────────────
POSTGRES_DB=sistema_prod
POSTGRES_USER=sistema_prod_user
POSTGRES_PASSWORD=GERE_SENHA_FORTE_AQUI_32_CHARS

# ── JWT (gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))") ──
JWT_SECRET=GERE_SECRET_FORTE_AQUI_64_CHARS

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL=https://seudominio.com.br

# ── App ───────────────────────────────────────────────────────
NODE_ENV=production
