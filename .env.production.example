# ═══════════════════════════════════════════════════════════════
#  Variáveis de produção — Tecnikos SaaS
#  Copie para .env.production e preencha os valores reais
#  NUNCA commite este arquivo com valores reais
# ═══════════════════════════════════════════════════════════════

# ── Domínio ─────────────────────────────────────────────────
DOMAIN=tecnikos.com.br
EMAIL_ADMIN=admin@tecnikos.com.br

# ── Banco de dados ──────────────────────────────────────────
POSTGRES_DB=tecnikos_prod
POSTGRES_USER=tecnikos_user
POSTGRES_PASSWORD=GERE_SENHA_FORTE_AQUI_32_CHARS

# ── JWT (gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))") ──
JWT_SECRET=GERE_SECRET_FORTE_AQUI_64_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=604800

# ── URLs ────────────────────────────────────────────────────
FRONTEND_URL=https://tecnikos.com.br

# ── App ─────────────────────────────────────────────────────
NODE_ENV=production

# ── System SMTP (SaaS onboarding emails) ────────────────────
SYSTEM_SMTP_HOST=smtp.gmail.com
SYSTEM_SMTP_PORT=587
SYSTEM_SMTP_SECURE=false
SYSTEM_SMTP_USER=noreply@tecnikos.com.br
SYSTEM_SMTP_PASS=GERE_APP_PASSWORD_AQUI
SYSTEM_FROM_NAME=Tecnikos
SYSTEM_FROM_EMAIL=noreply@tecnikos.com.br
